# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# Exuno API bearer token (used by the panel backend to place orders).
EXUNO_TOKEN=your-exuno-api-token

# nginx-proxy-manager admin + panel Basic-Auth credentials (used by deploy.sh).
NPM_USER=info@botify.trade
NPM_PASS=your-npm-password
